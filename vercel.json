{
    "version": 2,
    "builds": [
      {
        "src": "api/bundle.py",
        "use": "@vercel/python"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "api/bundle.py"
      }
    ],
    "functions": {
      "api/bundle.py": {
        "includeFiles": "api/**/*.py"
      }
    }
  }